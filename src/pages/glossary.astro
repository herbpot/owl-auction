---
import Base from '../layouts/Base.astro';

const terms = [
  { ko: '실거래가', en: 'Actual Transaction Price', desc: '부동산이 실제로 거래된 가격. 국토부 실거래가 공개시스템(RTMS)에 신고·공개된다.' },
  { ko: '평단가', en: 'Price per Area', desc: '거래금액을 면적(㎡)으로 나눈 단위면적당 가격. 층·향·구조 차이를 배제하고 비교할 때 쓴다.' },
  { ko: '전용면적', en: 'Exclusive Area', desc: '방·거실 등 실제 거주자가 독점 사용하는 면적. 공급면적(주거공용+기타공용)보다 좁다.' },
  { ko: '공급면적', en: 'Supply Area', desc: '전용면적 + 주거공용면적(복도·계단) + 기타공용면적(엘리베이터·창고). 평수 계산 기준.' },
  { ko: '매매', en: 'Sale', desc: '소유권을 유상으로 이전하는 거래. 경매·공매와 구분된다.' },
  { ko: '거래량', en: 'Transaction Volume', desc: '일정 기간 체결된 거래 건수. 시장 활성도·유동성을 가늠하는 지표.' },
  { ko: '신고가', en: 'Reported Price', desc: '법원 등기부등본상 권리사항 기록 가격이 아닌, 실제 거래계약 금액.' },
  { ko: '실거래가 공개시스템', en: 'RTMS', desc: '국토교통부가 운영하는 부동산 실거래가 조회 포털. 아파트·오피스텔·상가 등 거래 내역을 공개.' },
  { ko: '시세', en: 'Market Price', desc: '해당 물건이 거래될 것으로 기대되는 통상적 가격. 실거래가가 시세 형성의 기준.' },
  { ko: '호가', en: 'Asking Price', desc: '매도인이 부르는 판매 희망가. 실거래가와는 다를 수 있음.' },
];
---
<Base title="실거래 용어집">
  <div class="gloss">
    <h1>용어집</h1>
    <p class="sub">실거래 리포트에 자주 등장하는 핵심 용어를 한 줄로 정리했습니다.</p>
    <dl>
      {terms.map((t) => (
        <div class="term">
          <dt>{t.ko}<span class="en">{t.en}</span></dt>
          <dd>{t.desc}</dd>
        </div>
      ))}
    </dl>
  </div>
</Base>
