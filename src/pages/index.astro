---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';

const reports = (await getCollection('reports'))
  .sort((a, b) => b.data.date.localeCompare(a.data.date))
  .slice(0, 3);
---

<Base title="실제 거래가, 데이터로 증명">
  <section class="hero">
    <div class="container">
      <h1>실제 거래가,<br/><span class="grad">데이터로 증명.</span></h1>
      <p class="lead">국토부 실거래가 공개시스템(RTMS) 기반의 실제 아파트 매매 거래. 평단가·거래량·시세 트렌드를 노이즈 없이 한눈에.</p>
      <div class="stats">
        <div class="stat"><div class="num">MONTHLY</div><div class="label">매월 실거래 수집</div></div>
        <div class="stat"><div class="num">PRICE</div><div class="label">평단가·거래량 분석</div></div>
        <div class="stat"><div class="num">TREND</div><div class="label">지역별 시세 트렌드</div></div>
      </div>
    </div>
  </section>

  <section class="section" id="reports">
    <div class="container">
      <h2>최신 실거래 리포트</h2>
      <p class="sub">국토부 RTMS 기반 실제 매매 거래 데이터.</p>
      <div class="grid">
        {reports.length === 0 ? (
          <p class="empty">실거래 데이터를 수집 중입니다. 곧 첫 리포트가 올라옵니다.</p>
        ) : reports.map((r) => (
          <a class="card" href={`/owl-auction/reports/${r.id}`}>
            <span class="tag">{r.data.region ?? r.data.type}</span>
            <h3>{r.data.title}</h3>
            <p>{r.data.summary}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="cta">
        <div>
          <h2>실거래 용어가 막막하다면</h2>
          <p class="sub">평단가·전용면적·실거래가 개념 한 곳에서. <a href="/owl-auction/glossary" class="link">용어집 보기 →</a></p>
        </div>
        <a href="/owl-auction/pro" class="btn">Pro 둘러보기</a>
      </div>
    </div>
  </section>
</Base>
