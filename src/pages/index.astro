---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';

const reports = (await getCollection('reports'))
  .sort((a, b) => b.data.date.localeCompare(a.data.date))
  .slice(0, 3);

const won = (n) => n ? (n / 100000000).toFixed(1) + '억' : '—';
---
<Base title="실제 물건의 ROI를 데이터로 증명">
  <section class="hero">
    <div class="container">
      <h1>실제 물건의<br/><span class="grad">ROI를 데이터로 증명.</span></h1>
      <p class="lead">감정가·최저매각가·권리 리스크를 정량화해 보여주는 프리미엄 경매 리포트. 노이즈 없는 한 건의 신호.</p>
      <div class="stats">
        <div class="stat"><div class="num">890+</div><div class="label">분석 완료 물건</div></div>
        <div class="stat"><div class="num">21.7%</div><div class="label">평균 예상 ROI</div></div>
        <div class="stat"><div class="num">3,100+</div><div class="label">누적 낙찰 사례</div></div>
      </div>
    </div>
  </section>

  <section class="section" id="reports">
    <div class="container">
      <h2>최신 물건 리포트</h2>
      <p class="sub">정량 스크리닝을 통과한 실제 경매 물건.</p>
      <div class="grid">
        {reports.map((r) => (
          <a class="card" href={`/owl-auction/reports/${r.id}`}>
            <span class="tag">{r.data.region ?? r.data.type}</span>
            <h3>{r.data.title}</h3>
            <p>{r.data.summary}</p>
            <div class="meta">
              <span>감정가 {won(r.data.appraisalPrice)}</span>
              <span class="roi">{r.data.roi ?? '—'}% ROI</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="cta">
        <div>
          <h2>권리 용어가 막막하다면</h2>
          <p class="sub">말소기준권리·인수권리 한 곳에서. <a href="/owl-auction/glossary" class="link">용어집 보기 →</a></p>
        </div>
        <a href="/owl-auction/pro" class="btn">Pro 둘러보기</a>
      </div>
    </div>
  </section>
</Base>
